APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8001
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_api_key_secret_or_auth_token
# Verified Greek caller ID (E.164) or a Twilio-owned number
TWILIO_FROM_NUMBER=+306972813080
# US Twilio number example:
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
# Comma-separated pool; one is picked at random per outbound call
ELEVENLABS_AGENT_IDS=agent_maria,agent_eleni,agent_sofia,agent_chrysi,agent_katerina
ELEVENLABS_AGENT_LLM=gemini-2.5-flash
ELEVENLABS_AGENT_LANGUAGE=el
# Prompt scenario: parking_report | cockroach_advocate | birthday_wish
PROMPT_SCENARIO=parking_report
ELEVENLABS_AGENT_PROMPT_PATH=prompts/worried_citizen_system.txt
ELEVENLABS_AGENT_FIRST_MESSAGE_PATH=prompts/worried_citizen_first_message.txt
ELEVENLABS_SYNC_AGENT_ON_STARTUP=true
ELEVENLABS_USE_RUNTIME_OVERRIDES=false

# Optional: inline prompt/first message instead of files (leave blank to use paths above)
ELEVENLABS_AGENT_SYSTEM_PROMPT=
ELEVENLABS_AGENT_FIRST_MESSAGE=

# Illegal parking report details (injected into agent dynamic variables)
REPORT_LOCATION=Mitrou Sarkoudinou 7, Neos Kosmos, Athens
REPORT_PLATE=ΙΗΧ9037
REPORT_CAR_COLOR=κόκκινο
REPORT_CAR_BRAND=Mercedes

# Optional voice overrides (per language). Leave blank to use the agent's default voice.
ELEVENLABS_VOICE_ID_EL=
ELEVENLABS_VOICE_ID_EN=

CSV_PATH=data/contacts.csv
# Default contact when run_calls.py is run without --contact (must match name column)
CALL_CONTACT=Marina
CALL_LOGS_DIR=call_logs
TIMEZONE=Europe/Athens
MAX_TURNS=3
CALL_TIMEOUT_SECONDS=60
# Hang up if not answered after this many rings (timeout = rings × seconds per ring)
CALL_MAX_RINGS=4
CALL_RING_SECONDS=5
